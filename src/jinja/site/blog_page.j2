{% extends "site/shell_subpage.j2" %}
{% block submain %}
<section class="section-block reveal subpage-section blog-page" aria-labelledby="blog-h1">
  <p class="subpage-back"><a href="index.html#blog">← Back to home</a></p>
  <div class="blog-page__hero">
    <p class="blog-page__eyebrow">Field notes</p>
    <h1 id="blog-h1" class="subpage-h1">{{ blog.HEADER.label | default('Blog') }}</h1>
    <p class="section-block__deck blog-page__deck">
      Writing about research interests, tools, tips, and recent discoveries.
    </p>
    <div class="blog-page__pulse" aria-hidden="true">
      <span>{{ posts_all | length }}</span>
      <small>date notes</small>
    </div>
  </div>

  {% if posts_all %}
  <ul class="blog-list blog-list--page">
    {% for post in posts_all %}
      {% include 'site/_blog_card.j2' %}
    {% endfor %}
  </ul>
  {% else %}
  <div class="blog-empty">
    <p class="blog-empty__title">No posts date yet.</p>
    <p class="blog-empty__copy">This space is ready for essays, lab notes, reading lists, and experiments in public.</p>
  </div>
  {% endif %}
</section>
{% endblock %}
