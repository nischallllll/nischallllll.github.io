{% from 'site/_helpers.j2' import project_data_category %}
{% set has_image = item.image | default('', true) %}
<li class="project-item active{% if not has_image %} project-item--text{% endif %}" data-filter-item data-category="{{ project_data_category(item) }}">
  <a class="project-link{% if not has_image %} project-link--text{% endif %}" href="{{ item.url }}" target="_blank" rel="noopener noreferrer">
    {% if has_image %}
    <figure class="project-img">
      <div class="project-item-icon-box"><ion-icon name="eye-outline"></ion-icon></div>
      <img src="{{ item.image }}" alt="{{ item.title }}" loading="lazy">
    </figure>
    {% endif %}
    <h3 class="project-title{% if not has_image %} project-title--text{% endif %}">{{ item.title }}</h3>
    <p class="project-category{% if not has_image %} project-category--text{% endif %}">{% if item.category is string %}{{ item.category }}{% else %}{{ item.category | join(', ') }}{% endif %}</p>
  </a>
</li>
