<section id="blog" class="section-block reveal" aria-labelledby="blog-title">
  <h2 id="blog-title" class="section-block__title">{{ blog.HEADER.label | default('Blog') }}</h2>

  {% if blog_has_more %}
  <p class="section-block__deck section-block__deck--landing-note">
    Showing {{ posts_landing | length }} of {{ posts_all | length }} — see the full list for filters.
  </p>
  {% endif %}

  <section class="blog-section blog-section--landing">
    <ul class="blog-list">
      {% for post in posts_landing %}
        {% include 'site/_blog_card.j2' %}
      {% endfor %}
    </ul>

    {% if blog_has_more %}
    <p class="section-view-all">
      <a href="{{ page_urls.blog }}" class="section-view-all__link">All blog posts →</a>
    </p>
    {% endif %}
  </section>
</section>